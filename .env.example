# ---------- OpenRouter ----------
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_HTTP_REFERER=http://127.0.0.1:5173
OPENROUTER_TITLE=AI Web Agent MVP

# ---------- Agent ----------
AGENT_MAX_STEPS=10
AGENT_MAX_CONTEXT_CHARS=12000

# ---------- Browser ----------
BROWSER_PROFILE_DIR=./browser_profile
# Открыть эту страницу в первой вкладке при старте бэкенда (пусто = не открывать)
BROWSER_STARTUP_URL=http://127.0.0.1:5173/

# ---------- Backend (optional runtime values) ----------
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001
# Разрешить отключение подтверждений опасных действий из UI (не рекомендуется для прода)
ALLOW_SKIP_GUARD_CONFIRMATIONS=false
# Разрешенные origin для CORS (через запятую)
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# ---------- Frontend ----------
VITE_BACKEND_HTTP_URL=http://127.0.0.1:8001
VITE_BACKEND_WS_URL=ws://127.0.0.1:8001
